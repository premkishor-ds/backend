# OpenAI
OPENAI_API_KEY=

# Optional model overrides (defaults are set in main.py)
OPENAI_RESPONSES_MODEL=gpt-4.1-mini
OPENAI_CHAT_COMPLETIONS_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector search: pool size, then diversify; max rows in Sources / context is SEARCH_RETRIEVED_MAX
SEARCH_VECTOR_POOL=40
SEARCH_RETRIEVED_MAX=5

# PostgreSQL (pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASS=

# Optional: full URL if you use it elsewhere
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
